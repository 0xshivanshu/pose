# ── Angle calculation ─────────────────────────────────────────────────────────
def calculate_angle(a, b, c):
    a, b, c = np.array(a), np.array(b), np.array(c)
    radians = np.arctan2(c[1]-b[1], c[0]-b[0]) - np.arctan2(a[1]-b[1], a[0]-b[0])
    angle = np.abs(radians * 180.0 / np.pi)
    return angle if angle <= 180.0 else 360 - angle


# ── MediaPipe joint adjacency graph (undirected) ──────────────────────────────
# Only body joints — wrists/hands (15,16,17,18,19,20,21,22) and
# face (0–10) are intentionally excluded from constraint expansion.
EXCLUDED_JOINTS = set(range(0, 11)) | set(range(15, 23)) | set(range(27, 33))

JOINT_GRAPH = {
    # Torso
    11: [12, 13, 23],   # left shoulder
    12: [11, 14, 24],   # right shoulder
    23: [11, 24, 25],   # left hip
    24: [12, 23, 26],   # right hip
    # Arms (stop before wrists)
    13: [11],           # left elbow  (15=left wrist — excluded)
    14: [12],           # right elbow (16=right wrist — excluded)
    # Legs
    25: [23, 27],       # left knee
    26: [24, 28],       # right knee
    27: [25, 29, 31],   # left ankle
    28: [26, 30, 32],   # right ankle
    29: [27, 31],       # left heel
    30: [28, 32],       # right heel
    31: [27, 29],       # left foot index
    32: [28, 30],       # right foot index
}

# ── Constraint metadata per triplet ──────────────────────────────────────────
# Each entry: (violation_type, buffer, feedback)
#   violation_type: "less_than"    → angle must stay BELOW mean+buffer (elbow flaring out)
#                   "greater_than" → angle must stay ABOVE mean-buffer (shrugging, collapsing)
#   buffer: degrees of tolerance around the measured mean
CONSTRAINT_RULES = {
    # Elbow flaring away from body — angle grows when arm drifts out, cap it
    (23, 11, 13): ("greater_than", 15, "Keep your elbow close to your body"),
    (24, 12, 14): ("greater_than", 15, "Keep your elbow close to your body"),
    # Shoulder shrugging — angle shrinks when shoulder rises, fire when too low
    (12, 11, 13): ("less_than", 15, "Keep your shoulders down and back"),
    (11, 12, 14): ("less_than", 15, "Keep your shoulders down and back"),
    # Torso leaning — angle shrinks when person leans back, fire when too low
    (25, 23, 11): ("less_than", 15, "Keep your torso upright, avoid leaning"),
    (26, 24, 12): ("less_than", 15, "Keep your torso upright, avoid leaning"),
    # Knee caving in — angle shrinks when knee collapses, fire when too low
    (23, 25, 27): ("less_than", 15, "Keep your knee tracking over your toes"),
    (24, 26, 28): ("less_than", 15, "Keep your knee tracking over your toes"),
    # Hip dropping — angle shrinks when hip tilts, fire when too low
    (11, 23, 25): ("less_than", 15, "Keep your hips level"),
    (12, 24, 26): ("less_than", 15, "Keep your hips level"),
    # Chest/torso collapse forward during squat/lunge — two-step expansion triplets
    (12, 24, 23): ("less_than", 15, "Keep your chest up"),
    (11, 23, 24): ("less_than", 15, "Keep your chest up"),
    # Hip abduction — knee drifting out from hip
    (26, 24, 23): ("less_than", 15, "Keep your hips square"),
    (25, 23, 24): ("less_than", 15, "Keep your hips square"),
    # Ankle rolling — angle shrinks when ankle collapses, fire when too low
    (25, 27, 29): ("less_than", 15, "Keep your ankle stable"),
    (26, 28, 30): ("less_than", 15, "Keep your ankle stable"),
}

FALLBACK_RULE = ("greater_than", 15, "Maintain proper form")

# Triplets that are geometrically valid but biomechanically meaningless — skip them
CONSTRAINT_BLACKLIST = {
    (24, 23, 11),
    (23, 11, 12),
    (11, 12, 24),
    (12, 24, 23),
    (25, 23, 24),
    (26, 24, 23),
}


# ── Joint sets: always defined as pairs (Left, Right) ────────────────────────
JOINT_PAIRS = {
    "Arm":      ([11, 13, 15], [12, 14, 16]),   # shoulder->elbow->wrist
    "Shoulder": ([23, 11, 13], [24, 12, 14]),   # hip->shoulder->elbow
    "Torso":    ([11, 23, 25], [12, 24, 26]),   # shoulder->hip->knee
    "Leg":      ([23, 25, 27], [24, 26, 28]),   # hip->knee->ankle
}

CANDIDATE_SETS = {}
for name, (left_idx, right_idx) in JOINT_PAIRS.items():
    CANDIDATE_SETS[f"Left {name}"]  = {"joints": left_idx,  "side": "left",  "group": name}
    CANDIDATE_SETS[f"Right {name}"] = {"joints": right_idx, "side": "right", "group": name}


# ── Scan video for all candidate joint angles ─────────────────────────────────
def scan_video(video_path):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        print(f"Could not open: {video_path}")
        return None

    histories = {name: [] for name in CANDIDATE_SETS}
    print("Scanning video...")

    if USE_LEGACY:
        with mp_pose.Pose(min_detection_confidence=0.5) as pose:
            while cap.isOpened():
                ret, frame = cap.read()
                if not ret:
                    break
                results = pose.process(cv2.cvtColor(frame, cv2.COLOR_BGR2RGB))
                if results.pose_landmarks:
                    lm = results.pose_landmarks.landmark
                    for name, meta in CANDIDATE_SETS.items():
                        idx = meta["joints"]
                        # Skip frame for this group if any joint is low confidence
                        if any(lm[i].visibility < 0.5 for i in idx):
                            continue
                        pts = [[lm[i].x, lm[i].y] for i in idx]
                        histories[name].append(calculate_angle(*pts))
    else:
        options = PoseLandmarkerOptions(
            base_options=BaseOptions(model_asset_path=MODEL_PATH),
            running_mode=vision.RunningMode.VIDEO,
        )
        fps = cap.get(cv2.CAP_PROP_FPS) or 30
        frame_idx = 0
        with PoseLandmarker.create_from_options(options) as landmarker:
            while cap.isOpened():
                ret, frame = cap.read()
                if not ret:
                    break
                timestamp_ms = int(frame_idx * 1000 / fps)
                mp_image = mp.Image(
                    image_format=mp.ImageFormat.SRGB,
                    data=cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                )
                result = landmarker.detect_for_video(mp_image, timestamp_ms)
                if result.pose_landmarks:
                    lm = result.pose_landmarks[0]
                    for name, meta in CANDIDATE_SETS.items():
                        idx = meta["joints"]
                        # Skip frame for this group if any joint is low confidence
                        if any(lm[i].visibility < 0.5 for i in idx):
                            continue
                        pts = [[lm[i].x, lm[i].y] for i in idx]
                        histories[name].append(calculate_angle(*pts))
                frame_idx += 1

    cap.release()

    if not any(histories.values()):
        print("No pose detected in any frame. Check your video file.")
        return None

    return histories

GROUP_VALIDITY = {
    "Arm":      {"min_range": 30,  "min_floor": 10},   # curls, press: decent range
    "Shoulder": {"min_range": 20,  "min_floor":  0},   # abduction
    "Torso":    {"min_range": 20,  "min_floor": 50},   # torso must stay somewhat upright
    "Leg":      {"min_range": 40,  "min_floor": 20},   # squats, lunges: large range

}

# ── Pick the most active joint group ─────────────────────────────────────────
def pick_winner(histories):
    group_scores = {}
    for name, meta in CANDIDATE_SETS.items():
        h = histories[name]
        if not h:
            continue
        std       = np.std(h)
        ang_range = np.max(h) - np.min(h)
        ang_min   = np.min(h)
        group     = meta["group"]

        # Validate this group meets its biomechanical plausibility thresholds
        rules = GROUP_VALIDITY.get(group, {"min_range": 20, "min_floor": 0})
        if ang_range < rules["min_range"]:
            continue   # barely moved — not the primary joint
        if ang_min < rules["min_floor"]:
            continue   # angle collapsed to impossible values — bad detection

        if group not in group_scores or std > group_scores[group]["score"]:
            group_scores[group] = {"score": std, "winner_side": meta["side"], "winner_name": name}

    if not group_scores:
        # Fallback: drop validity filters and just take highest std
        print("⚠️  No group passed validity filters — falling back to raw std.")
        for name, meta in CANDIDATE_SETS.items():
            h = histories[name]
            if not h:
                continue
            std   = np.std(h)
            group = meta["group"]
            if group not in group_scores or std > group_scores[group]["score"]:
                group_scores[group] = {"score": std, "winner_side": meta["side"], "winner_name": name}

    if not group_scores:
        return None

    best_group = max(group_scores, key=lambda g: group_scores[g]["score"])
    info = group_scores[best_group]
    return best_group, info["winner_name"], info["winner_side"]


# ── Build checkpoints from the angle history ──────────────────────────────────
def build_checkpoints(history, joints):
    n = len(history)
    quarter = max(1, n // 4)
    start_avg = np.mean(history[:quarter])
    end_avg   = np.mean(history[-quarter:])

    min_ang = int(np.min(history))
    max_ang = int(np.max(history))
    low_thresh  = min_ang + 20
    high_thresh = max_ang - 20

    if start_avg > end_avg + 5:
        return [
            {"type": "greater_than", "threshold": high_thresh, "joints": joints},
            {"type": "less_than",    "threshold": low_thresh,  "joints": joints},
        ]
    elif end_avg > start_avg + 5:
        return [
            {"type": "less_than",    "threshold": low_thresh,  "joints": joints},
            {"type": "greater_than", "threshold": high_thresh, "joints": joints},
        ]
    else:
        return [
            {"type": "less_than",    "threshold": low_thresh,  "joints": joints},
            {"type": "greater_than", "threshold": high_thresh, "joints": joints},
        ]


# ── Build constraints: expand one joint outward from active joints ────────────
def build_constraints(active_joints, landmarks_per_frame):
    """
    For each end of the active joint chain (first and last joint),
    find neighbours in JOINT_GRAPH that are:
      - not already in the active chain
      - not in EXCLUDED_JOINTS (wrists, hands, face)

    For each valid neighbour N of end joint E, form the triplet:
      (N, E, next_in_chain)
    then measure its mean angle across the video as the constraint threshold.
    """
    if not landmarks_per_frame:
        return []

    constraints = []
    seen_triplets = set()

    ends = [
        (active_joints[0],  active_joints[1]),   # proximal end
        (active_joints[-1], active_joints[-2]),   # distal end
    ]

    for end_joint, inward_joint in ends:
        for neighbour in JOINT_GRAPH.get(end_joint, []):
            if neighbour in active_joints or neighbour in EXCLUDED_JOINTS:
                continue
            triplet = (neighbour, end_joint, inward_joint)
            if triplet in seen_triplets:
                continue
            if triplet in CONSTRAINT_BLACKLIST:
                continue
            seen_triplets.add(triplet)

            # Measure this triplet's angle across every frame
            angles = []
            for lm in landmarks_per_frame:
                try:
                    # Skip frames where any joint in the triplet is uncertain
                    if any(lm[i].visibility < 0.5 for i in triplet):
                        continue
                    pts = [[lm[i].x, lm[i].y] for i in triplet]
                    angles.append(calculate_angle(*pts))
                except (IndexError, KeyError):
                    continue

            if not angles:
                continue

            mean_ang = int(np.mean(angles))
            std_ang  = np.std(angles)

            # Only emit a constraint if the joint varies less than the active joint.
            # Using a fixed 40-deg ceiling — constraints can drift somewhat (e.g.
            # torso lean during squat) but shouldn't be the primary mover.
            if std_ang > 40:
                continue

            violation_type, buffer, feedback = CONSTRAINT_RULES.get(triplet, FALLBACK_RULE)

            if violation_type == "greater_than":
                threshold = mean_ang + buffer   # ceiling: fire when angle rises above normal
            else:
                threshold = mean_ang - buffer   # floor: fire when angle drops below normal

            # Never emit a nonsensical threshold
            if threshold < 0:
                threshold = 0

            constraints.append({
                "type":      violation_type,
                "threshold": threshold,
                "joints":    list(triplet),
                "feedback":  feedback,
            })

    return constraints


# Format filename to exercise name
def format_name(video_path):
    stem = video_path.rsplit(".", 1)[0]
    stem = stem.replace("-", "_")
    parts = stem.split("_")
    words = []
    for part in parts:
        split = re.sub(r'([a-z])([A-Z])', r'\1 \2', part).split()
        words.extend(split)
    return " ".join(w.capitalize() for w in words if w)


# ── Main pipeline ─────────────────────────────────────────────────────────────
VIDEO_FILE = "high_knees.mp4"

# We need raw landmarks per frame for constraint angle measurement,
# so we do a second lightweight pass after the scan.
def collect_landmarks(video_path):
    """Return a list of landmark objects, one per frame where pose was detected."""
    cap = cv2.VideoCapture(video_path)
    frames_lm = []

    if USE_LEGACY:
        with mp_pose.Pose(min_detection_confidence=0.5) as pose:
            while cap.isOpened():
                ret, frame = cap.read()
                if not ret:
                    break
                results = pose.process(cv2.cvtColor(frame, cv2.COLOR_BGR2RGB))
                if results.pose_landmarks:
                    frames_lm.append(results.pose_landmarks.landmark)
    else:
        options = PoseLandmarkerOptions(
            base_options=BaseOptions(model_asset_path=MODEL_PATH),
            running_mode=vision.RunningMode.VIDEO,
        )
        fps = cap.get(cv2.CAP_PROP_FPS) or 30
        frame_idx = 0
        with PoseLandmarker.create_from_options(options) as landmarker:
            while cap.isOpened():
                ret, frame = cap.read()
                if not ret:
                    break
                timestamp_ms = int(frame_idx * 1000 / fps)
                mp_image = mp.Image(
                    image_format=mp.ImageFormat.SRGB,
                    data=cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                )
                result = landmarker.detect_for_video(mp_image, timestamp_ms)
                if result.pose_landmarks:
                    frames_lm.append(result.pose_landmarks[0])
                frame_idx += 1

    cap.release()
    return frames_lm


histories = scan_video(VIDEO_FILE)

if histories:
    result = pick_winner(histories)

    if result is None:
        print("Could not determine a winning joint group.")
    else:
        best_group, winner_name, winner_side = result
        history = histories[winner_name]

        left_key     = f"Left {best_group}"
        right_key    = f"Right {best_group}"
        left_joints  = CANDIDATE_SETS[left_key]["joints"]
        right_joints = CANDIDATE_SETS[right_key]["joints"]
        is_bilateral = (left_key in CANDIDATE_SETS and right_key in CANDIDATE_SETS)

        print(f"Winner group: {best_group} | Detected side: {winner_side}")

        plt.figure(figsize=(10, 4))
        plt.plot(history, label=winner_name)
        plt.title(f"Joint Angle Over Time - {best_group}")
        plt.xlabel("Frame")
        plt.ylabel("Angle (deg)")
        plt.legend()
        plt.tight_layout()
        plt.show()

        checkpoints = build_checkpoints(history, left_joints)

        # Collect raw landmarks for constraint measurement
        print("Collecting landmarks for constraint analysis...")
        landmarks_per_frame = collect_landmarks(VIDEO_FILE)
        constraints = build_constraints(left_joints, landmarks_per_frame)

        exercise_name = format_name(VIDEO_FILE)
        ex_id = exercise_name.lower().replace(" ", "_")

        exercise_output = [
            {
                "id":            ex_id,
                "name":          exercise_name,
                "isBilateral":   is_bilateral,
                "sideInversion": is_bilateral,
                "checkpoints":   checkpoints,
                "constraints":   constraints,
            }
        ]

        print("\nGENERATED JSON:")
        print(json.dumps(exercise_output, indent=2))

        with open(f"{ex_id}.json", "w") as f:
            json.dump(exercise_output, f, indent=2)
        print(f"\nSaved to {ex_id}.json")
