<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.pose.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@id/viewFinder"
        app:layout_constraintEnd_toEndOf="@id/viewFinder"
        app:layout_constraintStart_toStartOf="@id/viewFinder"
        app:layout_constraintTop_toTopOf="@id/viewFinder" />
    
    <!-- Scrim for readability at the top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/scrim_top"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Modern Header UI -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="48dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvExercise"
            style="@style/TextAppearance.Pose.Heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detecting..."
            android:textSize="20sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/accent_secondary" />

        <TextView
            android:id="@+id/tvCount"
            style="@style/TextAppearance.Pose.Stat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0"
            android:textSize="100sp" />

    </LinearLayout>

    <!-- Big Rest Timer Overlay -->
    <LinearLayout
        android:id="@+id/restTimerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#E6121212"
        tools:visibility="visible">

        <TextView
            style="@style/TextAppearance.Pose.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REST PERIOD"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:textColor="@color/accent_secondary" />

        <TextView
            android:id="@+id/tvRestTimer"
            style="@style/TextAppearance.Pose.Stat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:45"
            android:textSize="120sp" />
    </LinearLayout>

    <!-- Gesture Progress Overlay (End Session) -->
    <LinearLayout
        android:id="@+id/gestureFeedbackCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC121212"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            style="@style/TextAppearance.Pose.Heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ending Session"
            android:textSize="24sp" />

        <TextView
            style="@style/TextAppearance.Pose.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hold your position" />

        <ProgressBar
            android:id="@+id/gestureProgressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:layout_marginTop="32dp"
            android:max="3000"
            android:progress="0"
            android:progressTint="@color/accent_secondary"
            android:progressBackgroundTint="@color/divider_thin" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndSession"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:text="End Session"
        android:textColor="@color/text_low_emphasis"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>