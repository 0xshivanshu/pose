<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Pose" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/bg_main</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="android:textColorPrimary">@color/text_high_emphasis</item>
        <item name="android:textColorSecondary">@color/text_medium_emphasis</item>
        
        <!-- Shape -->
        <item name="cornerRadiusMedium">12dp</item>
    </style>

    <style name="Theme.Pose" parent="Base.Theme.Pose" />
    
    <!-- Custom Text Styles for the "Distinctive" feel -->
    <style name="TextAppearance.Pose.Heading" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_high_emphasis</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Pose.Stat" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">sans-serif-condensed-light</item>
        <item name="android:textColor">@color/text_high_emphasis</item>
        <item name="android:textSize">64sp</item>
        <item name="android:letterSpacing">-0.05</item>
    </style>

    <style name="TextAppearance.Pose.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_medium_emphasis</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>